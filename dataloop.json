{
    "name": "video-preprocess-app",
    "displayName": "Video Preprocess App",
    "description": "Unified Video Preprocess Application - metadata extraction and thumbnail generation",
    "attributes": {
        "Category": "Application",
        "Provider": "Dataloop",
        "Application Type": [
            "Preprocess"
        ],
        "Media Type": [
            "Video"
        ]
    },
    "codebase": {
        "type": "git",
        "gitUrl": "https://github.com/dataloop-ai-apps/video-preprocess.git",
        "gitTag": "2.1.5"
    },
    "version": "2.1.5",
    "scope": "public",
    "components": {
        "modules": [
            {
                "name": "video_preprocess_module",
                "entryPoint": "main.py",
                "className": "VideoPreprocess",
                "initInputs": [],
                "functions": [
                    {
                        "name": "on_create",
                        "description": "Run video preprocess - metadata extraction and/or thumbnail generation, controlled by trigger input configs",
                        "input": [
                            {
                                "type": "Item",
                                "name": "item"
                            },
                            {
                                "name": "extract_metadata",
                                "type": "Boolean"
                            },
                            {
                                "name": "extract_thumbnail",
                                "type": "Boolean"
                            },
                            {
                                "name": "thumbnail_size",
                                "type": "Integer"
                            },
                            {
                                "name": "max_file_size_mb",
                                "type": "Integer"
                            }
                        ],
                        "output": []
                    },
                    {
                        "name": "on_delete",
                        "description": "Delete resources created by video preprocess (thumbnail)",
                        "input": [
                            {
                                "type": "Item",
                                "name": "item"
                            }
                        ],
                        "output": []
                    }
                ]
            }
        ],
        "services": [
            {
                "name": "video-preprocess-app",
                "moduleName": "video_preprocess_module",
                "runtime": {
                    "podType": "regular-m",
                    "runnerImage": "gcr.io/viewo-g/piper/agent/cpu/video-preprocess:4",
                    "concurrency": 5,
                    "autoscaler": {
                        "type": "rabbitmq",
                        "minReplicas": 1,
                        "maxReplicas": 60,
                        "queueLength": 5,
                        "cooldownPeriod": 300,
                        "pollingInterval": 15
                    },
                    "preemptible": false
                },
                "botUserName": "pipelines@dataloop.ai",
                "executionTimeout": 10800,
                "drainTime": 600,
                "maxAttempts": 3,
                "onReset": "failed"
            }
        ],
        "triggers": [
            {
                "name": "video-preprocess-created-app",
                "namespace": "services.video-preprocess-app",
                "type": "Event",
                "scope": "system",
                "active": true,
                "template": true,
                "activation": {
                    "autoClone": true,
                    "cloneActiveDefault": true,
                    "overridable": false
                },
                "applyOnExistingProjects": true,
                "activateOnExistingProjects": false,
                "spec": {
                    "resource": "Item",
                    "actions": [
                        "Created",
                        "Clone"
                    ],
                    "executionMode": "Once",
                    "filter": {
                        "$or": [
                            {
                                "metadata": {
                                    "system": {
                                        "mimetype": "video/*"
                                    }
                                }
                            },
                            {
                                "$and": [
                                    {
                                        "metadata": {
                                            "system": {
                                                "shebang": {
                                                    "linkInfo": {
                                                        "mimetype": "video*"
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "metadata": {
                                            "system": {
                                                "shebang": {
                                                    "linkInfo": {
                                                        "type": "url"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                ]
                            }
                        ]
                    },
                    "operation": {
                        "type": "function",
                        "functionName": "on_create",
                        "serviceName": "video-preprocess-app"
                    },
                    "input": {
                        "extract_metadata": true,
                        "extract_thumbnail": true,
                        "thumbnail_size": 128,
                        "max_file_size_mb": 2000
                    }
                }
            },
            {
                "name": "video-preprocess-app-deleted",
                "namespace": "services.video-preprocess-app",
                "type": "Event",
                "scope": "system",
                "active": true,
                "template": true,
                "activation": {
                    "autoClone": true,
                    "cloneActiveDefault": true,
                    "overridable": false
                },
                "applyOnExistingProjects": true,
                "activateOnExistingProjects": false,
                "spec": {
                    "resource": "Item",
                    "actions": [
                        "Deleted"
                    ],
                    "executionMode": "Once",
                    "filter": {
                        "$or": [
                            {
                                "metadata": {
                                    "system": {
                                        "mimetype": "video/*"
                                    }
                                }
                            },
                            {
                                "$and": [
                                    {
                                        "metadata": {
                                            "system": {
                                                "shebang": {
                                                    "linkInfo": {
                                                        "mimetype": "video*"
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "metadata": {
                                            "system": {
                                                "shebang": {
                                                    "linkInfo": {
                                                        "type": "url"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                ]
                            }
                        ]
                    },
                    "input": {},
                    "operation": {
                        "type": "function",
                        "functionName": "on_delete",
                        "serviceName": "video-preprocess-app"
                    }
                }
            }
        ]
    }
}
